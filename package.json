{
  "name": "idpay-portal-welfare-frontend",
  "version": "1.0.0",
  "homepage": "portale-enti",
  "private": true,
  "dependencies": {
    "@date-io/date-fns": "^2.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/base": "^5.0.0-beta.70",
    "@mui/icons-material": "5.15.14",
    "@mui/lab": "5.0.0-alpha.177",
    "@mui/material": "5.18.0",
    "@mui/system": "5.18.0",
    "@mui/x-data-grid": "8.11.1",
    "@mui/x-date-pickers": "6.20.2",
    "@pagopa/mui-italia": "^2.3.0",
    "@pagopa/selfcare-common-frontend": "1.34.92",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "1.15.0",
    "core-js": "^3.37.1",
    "date-fns": "^2.28.0",
    "env-var": "^7.4.0",
    "formik": "^2.2.9",
    "fp-ts": "^2.16.6",
    "i18next": "^25.8.10",
    "io-ts": "^2.2.16",
    "jest-sonar-reporter": "^2.0.0",
    "lodash": "^4.17.21",
    "node-fetch": "^3.3.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "^11.4.2",
    "react-i18next": "^16.5.4",
    "react-markdown": "^8.0.3",
    "react-redux": "8.1.3",
    "react-router-dom": "^5.2.0",
    "react-router-hash-link": "^2.4.3",
    "react-scripts": "5.0.1",
    "react-use-scrollspy": "^3.0.1",
    "url": "^0.11.0",
    "yup": "^0.32.11"
  },
  "scripts": {
    "clean": "yarn clean:build && yarn clean:coverage && yarn clean:api-role-permission && yarn clean:api-initiative && yarn clean:api-groups && yarn clean:api-email-notification && yarn clean:api-merchants",
    "start": "craco start",
    "build": "craco build",
    "clean:build": "rimraf build",
    "test": "craco test -i",
    "test:coverage": "craco test -i --coverage --ci --testResultsProcessor jest-sonar-reporter",
    "clean:coverage": "rimraf coverage",
    "eject": "react-scripts eject",
    "lint-autofix": "eslint . -c .eslintrc.js --ext .ts,.tsx --fix .",
    "lint": "eslint . -c .eslintrc.js --ext .ts,.tsx --cache",
    "prettify": "prettier --write \"./**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "generate": "yarn generate:api-role-permission && yarn generate:api-initiative && yarn generate:api-groups && yarn generate:api-email-notification && yarn generate:api-merchants",
    "clean:api-role-permission": "rimraf src/api/generated/role-permission",
    "generate:api-role-permission": "yarn run clean:api-role-permission && swagger-typescript-api generate -p openApi/openapi.role-permission.yml -o src/api/generated/role-permission -n apiClient.ts --http-client axios --extract-enums --extract-request-params --extract-response-body --single-http-client",
    "clean:api-initiative": "rimraf src/api/generated/initiative",
    "generate:api-initiative": "yarn run clean:api-initiative && swagger-typescript-api generate -p openApi/openapi.initiative.yml -o src/api/generated/initiative -n apiClient.ts --http-client axios --extract-enums --extract-request-params --extract-response-body --single-http-client",
    "clean:api-groups": "rimraf src/api/generated/groups",
    "generate:api-groups": "yarn run clean:api-groups && swagger-typescript-api generate -p openApi/openapi.groups.yml -o src/api/generated/groups -n apiClient.ts --http-client axios --extract-enums --extract-request-params --extract-response-body --single-http-client",
    "clean:api-email-notification": "rimraf src/api/generated/email-notification",
    "generate:api-email-notification": "yarn run clean:api-email-notification && swagger-typescript-api generate -p openApi/openapi.email-notification.yml -o src/api/generated/email-notification -n apiClient.ts --http-client axios --extract-enums --extract-request-params --extract-response-body --single-http-client",
    "clean:api-merchants": "rimraf src/api/generated/merchants",
    "generate:api-merchants": "yarn run clean:api-merchants && swagger-typescript-api generate -p openApi/openapi.merchants.yml -o src/api/generated/merchants -n apiClient.ts --http-client axios --extract-enums --extract-request-params --extract-response-body --single-http-client"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "7.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@types/react-router-dom": "^5.1.8",
    "@types/react-router-hash-link": "^2.4.5",
    "@types/redux-logger": "^3.0.13",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "api-spec-converter": "^2.12.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-functional": "^4.2.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-react": "^7.26.1",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-sonarjs": "^0.14.0",
    "js-yaml": "^4.1.1",
    "mkdirp": "^3.0.1",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "swagger-typescript-api": "^13.6.5",
    "typescript": "5.8.3"
  },
  "resolutions": {
    "static-eval": "^2.0.2",
    "yargs": "^17.5.1",
    "jsonpath": "^1.1.1",
    "svgo": "^2.8.0",
    "json-schema-ref-parser": "^7.1.0",
    "z-schema": "^4.2.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "18",
    "react-redux": "8.1.3",
    "i18next": "25.8.10",
    "react-i18next": "16.5.4"
  },
  "jest": {
    "restoreMocks": true,
    "clearMocks": true,
    "resetMocks": true,
    "coveragePathIgnorePatterns": [
      "__tests__",
      "__mocks__",
      "src/locale",
      "src/api",
      "src/bootstrap.ts",
      "src/consentAndAnalyticsConfiguration.ts",
      "src/index.tsx",
      "src/reportWebVitals.ts",
      "src/routes.tsx"
    ],
    "moduleNameMapper": {
      "next/router": "<rootDir>/__mocks__/next/router.js",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy",
      "^.+\\.(jpg|jpeg|png|gif|webp|avif|svg)$": "<rootDir>/__mocks__/file-mock.js",
      "^@pagopa/mui-italia$": "<rootDir>/node_modules/@pagopa/selfcare-common-frontend/node_modules/@pagopa/mui-italia/dist/index.js",
      "^@pagopa/mui-italia/dist/(.*)$": "<rootDir>/node_modules/@pagopa/selfcare-common-frontend/node_modules/@pagopa/mui-italia/dist/$1",
      "^@pagopa/mui-italia/(.*)$": "<rootDir>/node_modules/@pagopa/selfcare-common-frontend/node_modules/@pagopa/mui-italia/dist/$1",
      "react-markdown": "<rootDir>/node_modules/react-markdown/react-markdown.min.js"
    }
  },
  "packageManager": "yarn@4.13.0"
}
