{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "strictFunctionTypes": false,
    "types": ["jest", "node"]
  },
  "include": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/setupTests.ts",
    "__mocks__/**/*.ts",
    "__mocks__/**/*.tsx",
    "__mocks__/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "Dangerfile.ts"
  ]
}
